# Database — SQLite para dev, Postgres para prod
DATABASE_URL=sqlite:///./elitecards.db
# Para Postgres en prod:
# DATABASE_URL=postgresql+psycopg2://elitecards:CHANGE_ME@db.host:5432/elitecards

REDIS_URL=redis://localhost:6379/0

# JWT — en prod, GENERA UNO con: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# Entorno: "dev" o "prod". En prod se activan HSTS + HTTPS redirect y se valida config.
ENV=dev

# CORS: lista separada por comas de orígenes autorizados (sin trailing slash)
ALLOWED_ORIGINS=http://localhost:5173

# Email backend: "console" imprime al log (dev), "smtp" manda real (prod)
EMAIL_BACKEND=console
EMAIL_FROM=noreply@elitecards.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# URL del frontend (se usa para construir links en emails)
FRONTEND_URL=http://localhost:5173
